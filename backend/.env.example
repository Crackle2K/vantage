# Vantage Rust Backend — environment variables
# Copy to .env and fill in values

# Security
SECRET_KEY=your-secret-key-min-32-chars-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# reCAPTCHA Enterprise (optional — leave blank to skip)
RECAPTCHA_ENTERPRISE_PROJECT_ID=
RECAPTCHA_ENTERPRISE_API_KEY=
RECAPTCHA_ENTERPRISE_SITE_KEY=
RECAPTCHA_SIGNUP_ACTION=SIGNUP
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_VERIFY_TIMEOUT_SECONDS=10

# URLs
API_URL=http://localhost:8000
RUST_API_URL=
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Redis (optional — leave blank to skip rate limiting)
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=120

# MongoDB
# Use a standard mongodb:// seed-list URI in deployment. The Rust build avoids
# the optional DNS SRV resolver to eliminate current hickory-proto advisories.
# For MongoDB Atlas, use the "Drivers" connection string without +srv.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=vantage

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Demo mode
DEMO_MODE=false
DEMO_LAT=37.7749
DEMO_LNG=-122.4194

# Server port
PORT=8000
