# MongoDB Configuration
# Local:
# MONGODB_URI=mongodb://localhost:27017
# Production (Atlas):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=vantage

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# API Configuration
API_URL=http://localhost:8000

# CORS Configuration
# Comma-separated list of exact frontend origins.
# Example production value:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174
# Optional regex for dynamic preview URLs (Vercel preview URLs are allowed by default in code).
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$|https://([a-zA-Z0-9-]+\.)*vercel\.app$

# Google OAuth 2.0 (Get from: https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
