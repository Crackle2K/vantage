# Vantage Rust Backend — environment variables
# Copy to .env and fill in values

# Auth session cookie lifetime for Supabase refresh tokens
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google
GOOGLE_API_KEY=

# reCAPTCHA Enterprise (optional — leave blank to skip)
RECAPTCHA_ENTERPRISE_PROJECT_ID=
RECAPTCHA_ENTERPRISE_API_KEY=
RECAPTCHA_ENTERPRISE_SITE_KEY=
RECAPTCHA_SIGNUP_ACTION=SIGNUP
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_VERIFY_TIMEOUT_SECONDS=10

# URLs
API_URL=http://localhost:8000
RUST_API_URL=
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=120

# Supabase (required for auth, Postgres data, storage, and realtime)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=

# Demo mode
DEMO_MODE=false
DEMO_LAT=37.7749
DEMO_LNG=-122.4194

# Server port
PORT=8000
